<!-- pages/editor/editor.wxml -->
<view class="editor-container">
  <!-- 标签选择 -->
  <picker mode="selector" range="{{pickerTags}}" range-key="name" value="{{selectedTagIndex}}" bindchange="onTagChange">
    <view class="tag-picker">
      <text class="picker-label">标签</text>
      <view class="picker-value">
        <text>{{selectedTag || '选择标签'}}</text>
        <text class="picker-arrow">▼</text>
      </view>
    </view>
  </picker>

  <!-- 文字输入 -->
  <textarea
    class="content-input"
    placeholder="记录今天的小事..."
    placeholder-class="placeholder"
    value="{{content}}"
    bindinput="onInput"
    maxlength="-1"
    auto-height
  ></textarea>

  <!-- 图片预览 -->
  <view class="images-grid" wx:if="{{images.length > 0}}">
    <view 
      class="image-item" 
      wx:for="{{images}}" 
      wx:key="*this"
    >
      <image 
        src="{{item}}" 
        mode="aspectFill" 
        class="preview-img"
        bindtap="previewImage"
        data-index="{{index}}"
      />
      <view 
        class="remove-btn" 
        bindtap="removeImage"
        data-index="{{index}}"
      >×</view>
    </view>
  </view>

  <!-- 底部工具栏 -->
  <view class="toolbar">
    <view class="tool-btn" bindtap="chooseImage">
      <text class="tool-icon">📷</text>
      <text class="tool-text">添加图片</text>
      <text class="tool-count">{{images.length}}/9</text>
    </view>
    <view class="save-btn" bindtap="save">保存</view>
  </view>

  <!-- 自定义标签输入弹窗 -->
  <view class="custom-tag-mask" wx:if="{{showCustomInput}}" bindtap="cancelCustomTag"></view>
  <view class="custom-tag-modal {{showCustomInput ? 'show' : ''}}">
    <view class="modal-title">添加自定义标签</view>
    <input 
      class="custom-input" 
      placeholder="请输入标签名称" 
      maxlength="6"
      bindinput="onCustomTagInput"
      focus="{{showCustomInput}}"
    />
    <view class="modal-buttons">
      <view class="modal-btn cancel" bindtap="cancelCustomTag">取消</view>
      <view class="modal-btn confirm" bindtap="confirmCustomTag">确定</view>
    </view>
  </view>
</view>
