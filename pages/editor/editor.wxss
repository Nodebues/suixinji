/* pages/editor/editor.wxss */
.editor-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 140rpx;
}

.tag-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 32rpx;
  font-size: 30rpx;
  color: #333;
}

.picker-arrow {
  font-size: 22rpx;
  color: #c5c5c5;
}

.input-wrapper {
  background: #fff;
  padding: 32rpx;
  flex: 1;
}

.content-input {
  width: 100%;
  height: 100%;
  min-height: 600rpx;
  font-size: 32rpx;
  line-height: 1.8;
  color: #333;
}

.placeholder {
  color: #b8b8b8;
}

.images-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 0 32rpx 32rpx;
  background: #fff;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.toolbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.tool-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tool-icon {
  font-size: 44rpx;
}

.tool-text {
  font-size: 28rpx;
  color: #666;
}

.tool-count {
  font-size: 24rpx;
  color: #bbb;
}

.save-btn {
  background: linear-gradient(135deg, #5B8FF9 0%, #7BA8F7 100%);
  color: #fff;
  padding: 24rpx 72rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
}

/* 自定义标签弹窗 */
.custom-tag-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 99;
}

.custom-tag-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0);
  width: 600rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  z-index: 100;
  transition: transform 0.25s ease;
}

.custom-tag-modal.show {
  transform: translate(-50%, -50%) scale(1);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 40rpx;
  color: #1a1a1a;
}

.custom-input {
  width: 100%;
  height: 96rpx;
  background: #f5f7fa;
  border-radius: 20rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.modal-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.modal-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  background: #f5f7fa;
  color: #666;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #5B8FF9 0%, #7BA8F7 100%);
  color: #fff;
}
