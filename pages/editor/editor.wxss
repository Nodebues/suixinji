/* pages/editor/editor.wxss */
.editor-container {
  min-height: 100vh;
  background: #fff;
  padding: 32rpx;
  padding-bottom: 160rpx;
}

.tag-section {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.tag-item {
  padding: 8rpx 20rpx;
  background: #f8f8f8;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #888;
  transition: all 0.2s;
}

.tag-item.selected {
  background: linear-gradient(135deg, #5B8FF9 0%, #7BA8F7 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(91, 143, 249, 0.3);
}

.tag-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.picker-label {
  font-size: 28rpx;
  color: #999;
}

.picker-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  font-size: 20rpx;
  color: #ccc;
}

.content-input {
  width: 100%;
  font-size: 30rpx;
  line-height: 1.6;
  min-height: 300rpx;
  color: #333;
}

.placeholder {
  color: #bbb;
}

.images-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 32rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.remove-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.toolbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.tool-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tool-icon {
  font-size: 36rpx;
}

.tool-text {
  font-size: 26rpx;
  color: #666;
}

.tool-count {
  font-size: 24rpx;
  color: #bbb;
  margin-left: 8rpx;
}

.save-btn {
  background: #5B8FF9;
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 自定义标签弹窗 */
.custom-tag-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 99;
}

.custom-tag-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0);
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  z-index: 100;
  transition: transform 0.2s;
}

.custom-tag-modal.show {
  transform: translate(-50%, -50%) scale(1);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
  color: #333;
}

.custom-input {
  width: 100%;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.modal-btn.cancel {
  background: #f5f7fa;
  color: #666;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #5B8FF9 0%, #7BA8F7 100%);
  color: #fff;
}
