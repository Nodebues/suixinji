<!-- pages/weather/weather.wxml -->
<view class="container">
  <block wx:if="{{loading}}">
    <view class="loading-wrap">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在获取天气...</text>
    </view>
  </block>

  <block wx:elif="{{error}}">
    <view class="error-wrap">
      <text class="error-icon">🌤</text>
      <text class="error-text">{{error}}</text>
      <button class="retry-btn" bindtap="loadWeather">重试</button>
    </view>
  </block>

  <block wx:else>
    <!-- 天气卡片 -->
    <view class="weather-card">
      <view class="location-row" bindtap="onLocationTap">
        <text class="location-icon">📍</text>
        <text class="location">{{location}}</text>
        <text class="location-arrow">▼</text>
      </view>
      <view class="temp-row">
        <view class="temp-main">{{temp}}</view>
        <view class="weather-info">
          <view class="weather-desc">{{weatherText}}</view>
          <view class="feels-like">体感 {{feelsLike}}</view>
        </view>
      </view>

      <view class="detail-row">
        <view class="detail-item">
          <text class="detail-icon">💧</text>
          <text class="detail-label">湿度</text>
          <text class="detail-value">{{humidity}}</text>
        </view>
        <view class="detail-item">
          <text class="detail-icon">💨</text>
          <text class="detail-label">风速</text>
          <text class="detail-value">{{windSpeed}}</text>
        </view>
        <view class="detail-item">
          <text class="detail-icon">🌡</text>
          <text class="detail-label">体感</text>
          <text class="detail-value">{{feelsLike}}</text>
        </view>
      </view>
    </view>

    <!-- 全天温度曲线 -->
    <view class="chart-section">
      <view class="chart-header">
        <view class="chart-title">
          <text class="title-icon">🌡</text>
          <text>24小时温度</text>
        </view>
        <view wx:if="{{selectedTime}}" class="chart-tooltip">
          <text class="tooltip-time">{{selectedTime}}</text>
          <text class="tooltip-temp">{{selectedTemp}}</text>
        </view>
        <view wx:else class="chart-hint">点击曲线查看温度</view>
      </view>
      <view class="temp-chart-area" bindtouchstart="onTempChartTouch" style="width: {{canvasWidth}}px;">
        <canvas canvas-id="tempChart" class="chart-canvas" style="width: {{canvasWidth}}px; height: 200px;"></canvas>
      </view>
    </view>

    <!-- 日出日落 -->
    <view class="sun-section" wx:if="{{chartData}}">
      <view class="sun-main-row">
        <view class="sun-current-time">
          <text class="current-time-value">{{chartData.currentTime}}</text>
          <text class="current-time-label">现在</text>
        </view>
        <view class="sun-arc-wrap">
          <canvas canvas-id="sunChart" class="sun-canvas"></canvas>
        </view>
        <view class="sun-countdown">
          <text class="countdown-status">{{chartData.currentHour >= chartData.sunriseHour && chartData.currentHour < chartData.sunsetHour ? '🌇 待日落' : '🌅 待日出'}}</text>
          <text class="countdown-value">{{chartData.remainingDaylight}}</text>
        </view>
      </view>
      
      <view class="sun-stats">
        <view class="sun-stat-item">
          <text class="stat-value">{{chartData.totalDaylight || '--'}}</text>
          <text class="stat-label">日照时长</text>
        </view>
        <view class="sun-stat-divider"></view>
        <view class="sun-stat-item">
          <text class="stat-value">{{chartData.sunriseTime || '--'}}</text>
          <text class="stat-label">日出</text>
        </view>
        <view class="sun-stat-divider"></view>
        <view class="sun-stat-item">
          <text class="stat-value">{{chartData.sunsetTime || '--'}}</text>
          <text class="stat-label">日落</text>
        </view>
      </view>

      <view class="sun-detail-times">
        <view class="sun-time-grid">
          <view class="time-item">
            <text class="time-icon">🌤</text>
            <text class="time-label">晨光</text>
            <text class="time-value">{{chartData.firstLight || '--:--'}}</text>
          </view>
          <view class="time-item">
            <text class="time-icon">🌅</text>
            <text class="time-label">日出</text>
            <text class="time-value">{{chartData.sunriseTime || '--:--'}}</text>
          </view>
          <view class="time-item">
            <text class="time-icon">🌇</text>
            <text class="time-label">日落</text>
            <text class="time-value">{{chartData.sunsetTime || '--:--'}}</text>
          </view>
          <view class="time-item">
            <text class="time-icon">🌙</text>
            <text class="time-label">昏影</text>
            <text class="time-value">{{chartData.lastLight || '--:--'}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="hint">下拉可刷新天气</view>
  </block>

  <!-- 地址选择弹窗 -->
  <view class="address-picker-mask" wx:if="{{showAddressPicker}}" bindtap="closeAddressPicker"></view>
  <view class="address-picker {{showAddressPicker ? 'show' : ''}}">
    <view class="picker-header">
      <text class="picker-title">选择地址</text>
      <text class="picker-close" bindtap="closeAddressPicker">✕</text>
    </view>

    <view class="picker-search">
      <input class="search-input" placeholder="搜索城市或地点" bindinput="onSearchInput" value="{{searchKeyword}}"/>
    </view>

    <!-- 搜索结果 -->
    <view class="search-results" wx:if="{{searchResults.length > 0}}">
      <view class="result-item" wx:for="{{searchResults}}" wx:key="index" bindtap="selectLocation" data-lat="{{item.lat}}" data-lon="{{item.lon}}" data-name="{{item.name}}">
        <text class="result-icon">🔍</text>
        <text class="result-name">{{item.name}}</text>
        <text class="result-add" catchtap="saveLocation" data-lat="{{item.lat}}" data-lon="{{item.lon}}" data-name="{{item.name}}">+ 保存</text>
      </view>
    </view>

    <!-- 已保存地址 -->
    <view class="saved-section" wx:if="{{savedLocations.length > 0}}">
      <view class="section-title">已保存地址</view>
      <view class="saved-item" wx:for="{{savedLocations}}" wx:key="index" bindtap="selectSavedLocation" data-lat="{{item.lat}}" data-lon="{{item.lon}}" data-name="{{item.name}}">
        <text class="saved-icon">📍</text>
        <text class="saved-name">{{item.name}}</text>
        <text class="saved-delete" catchtap="deleteSavedLocation" data-index="{{index}}">删除</text>
      </view>
    </view>

    <!-- 当前定位 -->
    <view class="current-location" bindtap="useCurrentLocation">
      <text class="current-icon">📌</text>
      <text class="current-name">使用当前定位</text>
    </view>
  </view>
</view>
