/* pages/weather/weather.wxss */
.container {
  padding: 32rpx;
  min-height: 100vh;
  background: #f5f7fa;
}

.loading-wrap,
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #5B8FF9;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.retry-btn {
  background: linear-gradient(135deg, #5B8FF9 0%, #7BA8F7 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 64rpx;
  border-radius: 40rpx;
  border: none;
}

/* 天气卡片 */
.weather-card {
  background: linear-gradient(165deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  color: #fff;
  box-shadow: 0 16rpx 48rpx rgba(15, 52, 96, 0.4);
  position: relative;
  overflow: hidden;
}

.weather-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.location-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.location-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.location {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

.temp-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.temp-main {
  font-size: 120rpx;
  font-weight: 200;
  line-height: 1;
  letter-spacing: -4rpx;
}

.weather-info {
  text-align: right;
}

.weather-desc {
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.feels-like {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.detail-row {
  display: flex;
  justify-content: space-around;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(255,255,255,0.15);
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.detail-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 6rpx;
}

.detail-value {
  font-size: 28rpx;
  font-weight: 600;
}

/* 温度曲线 */
.chart-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.chart-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 600;
}

.title-icon {
  margin-right: 10rpx;
  font-size: 32rpx;
}

.chart-tooltip {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #5B8FF9 0%, #7BA8F7 100%);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

.tooltip-time {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  margin-right: 12rpx;
}

.tooltip-temp {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.chart-hint {
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 16rpx;
}

.temp-chart-area {
  position: relative;
  margin-top: 8rpx;
}

.chart-canvas {
  width: 100%;
  display: block;
}

/* 日出日落 */
.sun-section {
  background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  margin-top: 24rpx;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.3);
}

.sun-main-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.sun-current-time {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
}

.current-time-value {
  font-size: 48rpx;
  font-weight: 600;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
}

.current-time-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 4rpx;
}

.sun-countdown {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
}

.countdown-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.countdown-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #fbbf24;
}

.countdown-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 2rpx;
}

.sun-arc-wrap {
  flex: 1;
  display: flex;
  justify-content: center;
}

.sun-canvas {
  width: 50%;
}

.sun-stats {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
}

.sun-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #fbbf24;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

.sun-stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.2);
}

.sun-detail-times {
  border-top: 1rpx solid rgba(255,255,255,0.1);
  padding-top: 24rpx;
}

.sun-time-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.time-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 12rpx;
}

.time-icon {
  font-size: 28rpx;
  margin-bottom: 6rpx;
}

.time-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 4rpx;
}

.time-value {
  font-size: 24rpx;
  font-weight: 500;
}

.hint {
  text-align: center;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 32rpx;
}

/* 地址选择器 */
.location-arrow {
  font-size: 20rpx;
  margin-left: 8rpx;
  opacity: 0.7;
}

.address-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 99;
}

.address-picker {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 100;
  max-height: 70vh;
}

.address-picker.show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.picker-close {
  font-size: 36rpx;
  color: #94a3b8;
  padding: 8rpx;
}

.picker-search {
  margin-bottom: 24rpx;
}

.search-input {
  width: 100%;
  height: 72rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-results {
  max-height: 300rpx;
  overflow-y: auto;
  margin-bottom: 24rpx;
}

.result-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.result-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.result-name {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
}

.result-add {
  font-size: 24rpx;
  color: #5B8FF9;
  padding: 8rpx 16rpx;
}

.saved-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 16rpx;
}

.saved-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.saved-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.saved-name {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
}

.saved-delete {
  font-size: 24rpx;
  color: #ff4d4f;
  padding: 8rpx 16rpx;
}

.current-location {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #5B8FF9 0%, #7BA8F7 100%);
  border-radius: 16rpx;
  margin-top: 16rpx;
}

.current-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.current-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}
