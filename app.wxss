/* app.wxss */
page {
  background-color: #fafafa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
}

.container {
  padding: 24rpx;
}

.btn-primary {
  background: #5B8FF9;
  color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 30rpx;
}

.btn-primary:active {
  background: #4A7BE0;
}
